/* 整体背景 */
.login-page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  padding: 100rpx 60rpx;
  box-sizing: border-box;
}

/* Logo 区域 */
.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}
.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  padding: 20rpx;
  margin: 0 auto 20rpx;
}
.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 表单区域 */
.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}
.input-group {
  border-bottom: 1rpx solid #eee;
  margin-bottom: 40rpx;
}
.input {
  font-size: 30rpx;
  padding: 20rpx 0;
}

/* 登录按钮 */
.login-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

/* 注册链接 */
.register-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
}
.link-text {
  color: #667eea;
  font-weight: bold;
}