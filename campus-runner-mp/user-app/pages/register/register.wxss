.register-page {
  background: #f5f7fa;
  min-height: 100vh;
  padding: 120rpx 60rpx;
  box-sizing: border-box;
}
.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
}
.header {
  text-align: center;
  margin-bottom: 60rpx;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.desc {
  font-size: 26rpx;
  color: #999;
}
.input-group {
  border-bottom: 1rpx solid #eee;
  margin-bottom: 40rpx;
}
.input {
  font-size: 30rpx;
  padding: 20rpx 0;
}
.register-btn {
  background: #42b983;
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}
.login-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
}
.link-text {
  color: #42b983;
  font-weight: bold;
}